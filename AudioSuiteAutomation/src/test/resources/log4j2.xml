<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">

    <Appenders>

        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} [%t] [%-5level] %-25c{1} - %msg%n"/>
        </Console>

        <File name="FileLogger"
              fileName="logs/Automation.log"
              append="false">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} [%t] [%-5level] %-25c{1} - %msg%n"/>
        </File>

    </Appenders>

    <Loggers>

        <!-- Suppress TestNG internal logs -->
        <Logger name="org.testng" level="OFF" additivity="false"/>
        <Logger name="org.testng.internal" level="OFF" additivity="false"/>
        <Logger name="org.testng.reporters" level="OFF" additivity="false"/>

        <!-- Suppress Selenium internal logs if desired -->
        <Logger name="org.openqa.selenium" level="WARN"/>

        <Root level="INFO">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="FileLogger"/>
        </Root>

    </Loggers>

</Configuration>